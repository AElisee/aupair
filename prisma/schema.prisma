// AuPair A.EU — Schéma Prisma complet
// Version 1.0

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  AU_PAIR
  FAMILLE
  AGENCE
  ADMIN
}

enum MaritalStatus {
  MARRIED
  SINGLE
  DIVORCED
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  MOBILE_MONEY
  CARD
  PAYPAL
}

enum Currency {
  EUR
  XOF
  USD
}

enum ProfileStatus {
  PENDING
  ACTIVE
  HIDDEN
  SUSPENDED
  DELETED
}

enum MessageStatus {
  SENT
  READ
  DELETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CountryType {
  ORIGIN
  HOST
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  password          String?
  passwordChangedAt DateTime?
  name              String?
  image             String?
  role              UserRole  @default(AU_PAIR)
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  auPairProfile    AuPairProfile?
  familyProfile    FamilyProfile?
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  subscriptions    Subscription[]
  favoritesAsUser  Favorite[]     @relation("FavoriteUser")
  favoritedBy      Favorite[]     @relation("FavoriteTarget")
  reportsMade      Report[]       @relation("Reporter")
  reportsReceived  Report[]       @relation("Reported")
  tickets          Ticket[]
  notifications    Notification[]
  blockedUsers     Block[]        @relation("Blocker")
  blockedBy        Block[]        @relation("Blocked")
  profileViewsMade     ProfileView[] @relation("ProfileViewViewer")
  profileViewsReceived ProfileView[] @relation("ProfileViewTarget")
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── RÉINITIALISATION DE MOT DE PASSE ────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── PROFIL AU PAIR ──────────────────────────────────────────────────────────

model AuPairProfile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  status              ProfileStatus @default(PENDING)

  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              String
  nationality         String
  countryOfOrigin     String
  cityOfOrigin        String?

  languages           String[]
  educationLevel      String?
  childcareExperience String?       @db.Text
  childcareYears      Int?
  firstAidCertified   Boolean       @default(false)
  drivingLicense      Boolean       @default(false)

  targetCountries     String[]
  availableFrom       DateTime?
  availableTo         DateTime?
  preferredDuration   String?
  isAvailable         Boolean       @default(true)

  isSmoker            Boolean       @default(false)
  healthDeclaration   String?       @db.Text
  hasCriminalRecord   Boolean       @default(false)

  description         String?       @db.Text
  motivation          String?       @db.Text

  phoneWhatsapp1      String?
  phoneWhatsapp2      String?
  profilePhotoUrl     String?
  idDocumentUrls      String[]      @default([])

  profileViews        Int           @default(0)
  validatedAt         DateTime?
  validatedBy         String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("au_pair_profiles")
}

// ─── PROFIL FAMILLE ──────────────────────────────────────────────────────────

model FamilyProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  status             ProfileStatus @default(PENDING)

  country            String
  city               String
  address            String?

  maritalStatus      MaritalStatus
  parentsAges        Int[]
  numberOfKids       Int
  kidsAges           Int[]

  auPairTasks        String?       @db.Text
  hoursPerWeek       Int?
  pocketMoney        Float?
  accommodation      String?
  mealsProvided      Boolean       @default(true)

  description        String?       @db.Text
  familyPhotoUrl     String?

  phoneWhatsapp      String?

  preferredGender    String?
  preferredAgeMin    Int?
  preferredAgeMax    Int?
  preferredLanguages String[]

  profileViews       Int           @default(0)
  validatedAt        DateTime?
  validatedBy        String?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("family_profiles")
}

// ─── ABONNEMENTS ─────────────────────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  userId        String
  status        SubscriptionStatus @default(ACTIVE)
  amount        Float
  currency      Currency           @default(EUR)
  paymentMethod PaymentMethod
  paymentId     String?
  invoiceUrl    String?

  startsAt      DateTime           @default(now())
  expiresAt     DateTime

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── MESSAGERIE ──────────────────────────────────────────────────────────────

model Message {
  id             String        @id @default(cuid())
  senderId       String
  receiverId     String
  content        String        @db.Text
  attachmentUrl  String?
  attachmentType String?
  attachmentName String?
  status         MessageStatus @default(SENT)
  isFlagged      Boolean       @default(false)
  createdAt      DateTime      @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@map("messages")
}

// ─── FAVORIS ─────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  targetId  String
  createdAt DateTime @default(now())

  user   User @relation("FavoriteUser", fields: [userId], references: [id], onDelete: Cascade)
  target User @relation("FavoriteTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
  @@map("favorites")
}

// ─── SIGNALEMENTS ────────────────────────────────────────────────────────────

model Report {
  id          String    @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String
  description String?   @db.Text
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ─── BLOCAGES ────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

// ─── BLOG ────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  titleEn     String?
  content     String    @db.Text
  contentEn   String?   @db.Text
  excerpt     String?
  excerptEn   String?
  coverImage  String?
  category    String
  tags        String[]
  author      String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─── FAQ ─────────────────────────────────────────────────────────────────────

model FaqItem {
  id          String   @id @default(cuid())
  question    String
  questionEn  String?
  answer      String   @db.Text
  answerEn    String?  @db.Text
  category    String
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("faq_items")
}

// ─── TÉMOIGNAGES ─────────────────────────────────────────────────────────────

model Testimonial {
  id            String   @id @default(cuid())
  authorName    String
  authorRole    String
  authorCountry String
  authorPhoto   String?
  content       String   @db.Text
  contentEn     String?  @db.Text
  rating        Int      @default(5)
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("testimonials")
}

// ─── PAYS ────────────────────────────────────────────────────────────────────

model Country {
  id        String      @id @default(cuid())
  name      String      @unique
  flag      String
  dialCode  String
  type      CountryType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("countries")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── VUES DE PROFIL ──────────────────────────────────────────────────────────

model ProfileView {
  id            String   @id @default(cuid())
  viewerId      String
  profileUserId String
  weekKey       String
  lastViewedAt  DateTime @default(now())

  viewer      User @relation("ProfileViewViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileUser User @relation("ProfileViewTarget", fields: [profileUserId], references: [id], onDelete: Cascade)

  @@unique([viewerId, profileUserId])
  @@map("profile_views")
}

// ─── TICKETS SUPPORT ─────────────────────────────────────────────────────────

model Ticket {
  id          String         @id @default(cuid())
  userId      String?
  guestName   String?
  guestEmail  String?
  subject     String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?
  resolvedAt  DateTime?
  messages    TicketMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// ─── PARAMÈTRES (constantes éditables par l'admin) ───────────────────────────

model AppSettings {
  id                   String   @id @default("default")
  languages            String[]
  educationLevels      String[]
  durations            String[]
  reportReasons        String[]
  subscriptionPriceEur Float    @default(32)
  subscriptionPriceXof Float    @default(20800)
  subscriptionDays     Int      @default(30)
  subscriptionFeatures String[] @default(["Profil visible par toutes les familles d'accueil", "Messagerie illimitée avec les familles", "Accès aux coordonnées des familles", "Système de favoris", "Notifications de nouveaux profils correspondants", "Support prioritaire"])

  notifyProfileViewEnabled       Boolean @default(true)
  notifyWeeklyViewsDigestEnabled Boolean @default(true)

  // Configuration de l'envoi d'emails (Resend) — éditable par l'admin, jamais stockée en .env
  resendApiKey String?
  emailFrom    String?

  // Configuration des paiements Stripe — éditable par l'admin, jamais stockée en .env
  stripeSecretKey     String?
  stripeWebhookSecret String?

  updatedAt            DateTime @updatedAt

  @@map("app_settings")
}
